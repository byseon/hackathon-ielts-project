# Copy to .env (gitignored) and fill in. NEVER commit real keys.
#   cp .env.example .env
#
# ONE Tavus key covers STT, TTS, a hosted LLM, and the Knowledge Base (RAG),
# plus hackathon credits. So in most cases TAVUS_API_KEY is all you need.

# --- Tavus (conversation + STT + LLM + Knowledge Base) ------------------- #
# https://platform.tavus.io -> API Keys (ask a Tavus team member for credits).
TAVUS_API_KEY=
TAVUS_PAL_ID=          # examiner persona id (create once, then reuse)
TAVUS_FACE_ID=         # examiner avatar/replica id (a stock face is fine to start)
# In-call STT engine: tavus-soniox keeps fillers; tavus-parakeet = low-latency English
TAVUS_STT_ENGINE=tavus-soniox

# --- Knowledge Base / RAG (built into Tavus — no vector DB needed) -------- #
# Upload band descriptors + question banks via POST /v2/documents, then attach
# them to conversations by tag. These are just the tag names you chose.
TAVUS_DOCUMENT_TAGS=ielts-rubric,ielts-questions

# --- LLM for off-call rubric judges (OpenAI-compatible) ------------------ #
# Defaults to Tavus's hosted LLM so you can reuse the Tavus key. Point BASE_URL
# at any OpenAI-compatible provider to bring your own.
# NOTE: verify the exact Tavus LLM base URL/model in the hackathon dashboard/docs.
LLM_BASE_URL=          # e.g. Tavus LLM endpoint; blank => set before running judges
LLM_API_KEY=           # blank => falls back to TAVUS_API_KEY
LLM_MODEL=llama-3.3-70b

# --- Pronunciation + word-timing backbone (local, MIT, no key) ----------- #
# Charsiu forced alignment on the recording audio gives word/phone timings + GOP.
CHARSIU_MODEL=charsiu/en_w2v2_fc_10ms

# --- Demo server --------------------------------------------------------- #
PORT=8000
