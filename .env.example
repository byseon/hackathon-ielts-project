# Copy to .env (gitignored) and fill in. NEVER commit real keys.
#   cp .env.example .env

# --- Tavus CVI (the conversation layer) ---------------------------------- #
# From https://platform.tavus.io -> API Keys. Needed to create PALs, Faces,
# and Conversations, and to drive the in-call examiner.
TAVUS_API_KEY=
TAVUS_PAL_ID=          # examiner persona id (create once, then reuse)
TAVUS_FACE_ID=         # examiner avatar/replica id (a stock face is fine to start)
# In-call STT engine: tavus-soniox keeps fillers; tavus-parakeet = low-latency English
TAVUS_STT_ENGINE=tavus-soniox

# --- Assessment-grade STT (re-transcribe per-turn audio, verbatim) -------- #
# Soniox direct API: word timestamps + confidence, disfluencies KEPT.
SONIOX_API_KEY=

# --- LLM rubric judges (Layer B) ----------------------------------------- #
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-haiku-4-5-20251001   # low-hallucination, low-latency judging

# --- Pronunciation (Layer A) --------------------------------------------- #
# Charsiu (MIT) runs locally — no key. Override the model id if needed.
CHARSIU_MODEL=charsiu/en_w2v2_fc_10ms

# --- RAG store (optional: band descriptors + exemplars) ------------------ #
# Postgres + pgvector, or leave blank to use the in-memory NullRAG.
DATABASE_URL=

# --- Demo server --------------------------------------------------------- #
PORT=8000
